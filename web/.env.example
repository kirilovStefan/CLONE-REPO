# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.

# Neon Postgres connection string (Neon dashboard → Connection Details).
# Looks like: postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# Secret used to sign auth sessions/JWTs (generate a long random string).
AUTH_SECRET=

# Public base URL of the app (used for emails, booking links, OAuth callbacks).
# Local: http://localhost:3000 · Production: your Render URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
